# ─────────────────────────────────────────────────────────────
# Configurazione dell'intero stack (letta da docker-compose).
# Copia questo file in ".env" e adatta i valori:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# --- Porte esposte sull'host ---
SERVER_PORT=3001
CLIENT_PORT=3000

# --- Backend ---
# Origini ammesse dal CORS (lista separata da virgole per più domini).
CORS_ORIGIN=http://localhost:3000

# --- Frontend ---
# URL del server Socket.IO usato dal browser (inglobato a build time).
VITE_SOCKET_URL=http://localhost:3001
